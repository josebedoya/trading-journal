# ──────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y rellena los valores.
# Los valores por defecto corresponden al stack local de Supabase
# (`supabase start`). En la nube, toma los valores del dashboard.
# ──────────────────────────────────────────────────────────────

# Conexión Postgres para Drizzle (puerto por defecto de Supabase local: 54322)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Supabase (Auth / Storage) — en migración a Better Auth + R2 (se removerá).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Storage S3-compatible.
#  Dev (MinIO, `docker compose up -d minio`):
S3_ENDPOINT="http://127.0.0.1:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="screenshots"
#  Nube (Cloudflare R2):
#   S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
#   S3_REGION="auto"
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = R2 API token
#   S3_BUCKET="<tu-bucket>"
