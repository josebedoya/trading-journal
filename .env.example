# ──────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y rellena los valores.
# Los valores por defecto corresponden al stack local vía Docker
# (`docker compose up -d`): Postgres + MinIO. En la nube: Neon + R2.
# ──────────────────────────────────────────────────────────────

# Conexión Postgres para Drizzle.
#  Dev (contenedor `db` de docker-compose):
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/trading_journal"
#  Nube (Neon): usa la connection string del dashboard (con ?sslmode=require).

# Driver de Drizzle: "node" (node-postgres) en local, "neon" (neon-serverless,
# WebSocket, soporta transacciones) en producción. Si se omite se infiere de
# NODE_ENV ("node" en dev, "neon" en producción).
DB_DRIVER="node"

# Better Auth (auth por email/contraseña).
#  Genera el secreto con: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Storage S3-compatible.
#  Dev (MinIO, `docker compose up -d`):
S3_ENDPOINT="http://127.0.0.1:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="screenshots"
#  Nube (Cloudflare R2):
#   S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
#   S3_REGION="auto"
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = R2 API token
#   S3_BUCKET="<tu-bucket>"
