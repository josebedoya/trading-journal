# ──────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y rellena los valores.
# Los valores por defecto corresponden al stack local de Supabase
# (`supabase start`). En la nube, toma los valores del dashboard.
# ──────────────────────────────────────────────────────────────

# Conexión Postgres para Drizzle (puerto por defecto de Supabase local: 54322)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Supabase (Auth / Storage). `supabase start` imprime estos valores.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
